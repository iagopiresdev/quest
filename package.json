{
  "name": "quest",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iagopiresdev/quest.git"
  },
  "bugs": {
    "url": "https://github.com/iagopiresdev/quest/issues"
  },
  "homepage": "https://github.com/iagopiresdev/quest#readme",
  "packageManager": "bun@1.3.9",
  "type": "module",
  "description": "CLI-first worker registry and quest planner for parallel agent execution",
  "keywords": [
    "agents",
    "bun",
    "cli",
    "orchestration",
    "parallel-execution",
    "quest"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "bin",
    "dist",
    "docs/assets",
    "docs/design-system.mdx",
    "docs/engineering-guide.mdx",
    "docs/operator-guide.mdx",
    "docs/pull-request-workflow.mdx",
    "docs/release-platform-support.mdx",
    "docs/specs",
    "index.mdx",
    "config",
    "docs.json",
    "src",
    "scripts"
  ],
  "engines": {
    "bun": ">=1.3.9"
  },
  "bin": {
    "quest": "./bin/quest"
  },
  "scripts": {
    "build": "mkdir -p dist && bun build --compile ./src/cli.ts --outfile ./dist/quest",
    "check": "bun run lint && bun run typecheck && bun run test:ci && bun run build",
    "docs:dev": "npx mint dev --no-open",
    "format": "biome format . --write",
    "hooks:install": "bash ./scripts/install-git-hooks.sh",
    "install:local": "bash ./scripts/install-local.sh",
    "lint": "biome check . && bun run lint:cycles && bun run lint:architecture",
    "lint:architecture": "bun ./scripts/lint-architecture.ts",
    "lint:cycles": "madge --circular --extensions ts --ts-config tsconfig.json src",
    "lint:fix": "biome check . --write",
    "quest": "./bin/quest",
    "readme:demo": "vhs docs/assets/readme/quest-demo.tape",
    "test:coverage": "bun test --coverage",
    "test:ci": "bun test",
    "test": "bun test",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "madge": "^8.0.0",
    "typescript": "^6.0.2"
  }
}
